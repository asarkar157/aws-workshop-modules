            "description": "This is a policy that is used in for reading secrets from aws secrets manager. but the only secrets that can be read are secrets with tag stackgen=true",
            "id": "arn:aws:iam::180217099948:policy/stackgen-external-secrets-integration-example",
            "name": "stackgen-external-secrets-integration-example",
            "name_prefix": "",
            "path": "/",
            "policy": "{\"Statement\":[{\"Action\":\"secretsmanager:ListSecrets\",\"Effect\":\"Allow\",\"Resource\":\"*\",\"Sid\":\"AllowListSecrets\"},{\"Action\":\"secretsmanager:GetSecretValue\",\"Condition\":{\"StringEquals\":{\"aws:ResourceTag/stackgen\":\"true\"}},\"Effect\":\"Allow\",\"Resource\":\"*\",\"Sid\":\"AllowGetSecretWithTag\"}],\"Version\":\"2012-10-17\"}",
            "policy_id": "ANPAST5OGW2WJ3K2PBQOI",
            "tags": {
              "do-not-delete": "true"
            },
            "tags_all": {
              "do-not-delete": "true"
            }
          },
          "sensitive_attributes": [],
          "private": "eyJzY2hlbWFfdmVyc2lvbiI6MH0=",
          "dependencies": [
            "aws_vpc.aws_aidevops_default_vpc",
            "aws_launch_template.lt_09941c90104dafb26"
          ]
        }
      ]
